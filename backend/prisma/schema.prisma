datasource db {
  provider = "postgresql"

}

generator client {
  provider = "prisma-client"
    output   = "../generated/prisma"
}

model User {
  id Int @id @default(autoincrement())
  name String
  email String @unique
  password String

  board Board[]
}

model Board {
  id Int @id @default(autoincrement())
  title String
  userId Int

  user User @relation(fields:[userId], references:[id])
}