{
  "compilerOptions": {
    /* === Base === */
    "target": "ES2020",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    /* === Node environment === */
    "types": ["node"],
    "lib": ["ES2020"],

    /* === Strict mode (important en pro) === */
    "strict": true,

    /* === Interop === */
    "esModuleInterop": true,
    "resolveJsonModule": true,

    /* === Quality === */
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "skipLibCheck": true
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
